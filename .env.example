# Copy this file to .env for local development
# In production (Railway), set these as environment variables in the dashboard.

# Postgres connection string. Railway sets this automatically when you attach a Postgres plugin.
DATABASE_URL=postgres://user:password@host:5432/flora

# Secret used to sign JWT auth tokens. Generate a strong random string for production.
JWT_SECRET=change-me-to-a-long-random-string

# Optional: server port (Railway provides PORT automatically).
PORT=3000

# Optional: set to 'production' on Railway. Locally leave as 'development'.
NODE_ENV=development
