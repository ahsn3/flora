# Copy this file to .env for local development
# In production (Railway), set these as environment variables in the dashboard.

# ──── Database ───────────────────────────────────────────────
# Postgres connection string. Railway sets this automatically when you attach
# the Postgres plugin.
DATABASE_URL=postgres://user:password@host:5432/flora

# ──── Auth ───────────────────────────────────────────────────
# Secret used to sign JWT tokens. Generate a strong random string for prod, e.g.
#   openssl rand -hex 48
JWT_SECRET=change-me-to-a-long-random-string

# ──── Server ─────────────────────────────────────────────────
# Railway provides PORT automatically. Locally, 3000 is fine.
PORT=3000

# Set to 'production' on Railway so the Postgres driver enables SSL.
NODE_ENV=development

# ──── Email (PIN verification) ───────────────────────────────
# Required to actually send signup verification codes. If unset, PINs are
# printed to the server console (dev fallback).
#
# Pick ONE provider — examples below. The frontend works the same either way.
#
# ── Gmail (free, uses an "App password" — NOT your normal Gmail password) ──
#   1. Enable 2-step verification on your Google account
#   2. Visit https://myaccount.google.com/apppasswords and create one for "Mail"
#   3. Use the 16-character password below
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.address@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=Flora & Gifts <your.address@gmail.com>
#
# ── Resend (resend.com — modern, simple) ──
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxx
# SMTP_FROM=Flora & Gifts <onboarding@yourdomain.com>
# SMTP_SECURE=true
#
# ── SendGrid ──
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxx
# SMTP_FROM=Flora & Gifts <hello@yourdomain.com>
#
# ── Brevo / Sendinblue (300 free emails/day) ──
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login@example.com
# SMTP_PASS=xxxxxxxxxxxxxxxx
# SMTP_FROM=Flora & Gifts <hello@yourdomain.com>

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Flora & Gifts <no-reply@flora.local>
SMTP_SECURE=false
